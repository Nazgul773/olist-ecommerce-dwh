    // ── Customer — Base ───────────────────────────────────────────────────────
    new { Name = "Avg Review Score",
          Dax = "AVERAGEX(FILTER('mart fact_sales', NOT ISBLANK('mart fact_sales'[review_score])), 'mart fact_sales'[review_score])",
          Folder = "Customer" },
    new { Name = "Unique Customers",
          Dax = "DISTINCTCOUNT('mart fact_sales'[customer_key])",
          Folder = "Customer" },
    new { Name = "Review Submission Rate",
          Dax = "DIVIDE(\n    CALCULATE(\n        DISTINCTCOUNT('mart fact_sales'[order_id]),\n        NOT ISBLANK('mart fact_sales'[review_score])\n    ),\n    [Total Orders]\n)",
          Folder = "Customer" },
    // ── Customer — Formatted ──────────────────────────────────────────────────
    new { Name = "Unique Customers Formatted",
          Dax = "VAR _val = [Unique Customers]\nRETURN\n    SWITCH(TRUE(),\n        _val >= 1000000, FORMAT(_val / 1000000, \"0.0\") & \"M\",\n        _val >= 1000,    FORMAT(_val / 1000, \"0.0\") & \"K\",\n                         FORMAT(_val, \"#,##0\"))",
          Folder = "Customer" },

// Tabular Editor 2 — Bulk-create all DAX measures for the Olist dashboard.
// Usage: open Power BI Desktop with the model, launch Tabular Editor via External Tools,
//        paste this script into the C# Script tab and press F5, then Ctrl+S.

foreach(var m in Model.Tables["_Measures"].Measures.ToList()) m.Delete();

var t = Model.Tables["_Measures"];

var defs = new[] {
    // ── Revenue — Base ────────────────────────────────────────────────────────
    new { Name = "Total Revenue",
          Dax = "SUM('mart fact_sales'[total_value])",
          Folder = "Revenue" },
    new { Name = "Total Orders",
          Dax = "DISTINCTCOUNT('mart fact_sales'[order_id])",
          Folder = "Revenue" },
    new { Name = "Avg Order Value",
          Dax = "DIVIDE([Total Revenue], [Total Orders])",
          Folder = "Revenue" },
    new { Name = "Total Items Sold",
          Dax = "COUNTROWS('mart fact_sales')",
          Folder = "Revenue" },
    new { Name = "Avg Item Price",
          Dax = "AVERAGE('mart fact_sales'[price])",
          Folder = "Revenue" },
    new { Name = "Avg Freight Value",
          Dax = "AVERAGE('mart fact_sales'[freight_value])",
          Folder = "Revenue" },
    new { Name = "Freight Share %",
          Dax = "DIVIDE(SUM('mart fact_sales'[freight_value]), SUM('mart fact_sales'[total_value]))",
          Folder = "Revenue" },
    // ── Revenue — Formatted ───────────────────────────────────────────────────
    new { Name = "Total Revenue Formatted",
          Dax = "VAR _val = [Total Revenue]\nRETURN\n    SWITCH(TRUE(),\n        _val >= 1000000, \"R$ \" & FORMAT(_val / 1000000, \"0.0\") & \"M\",\n        _val >= 1000,    \"R$ \" & FORMAT(_val / 1000, \"0.0\") & \"K\",\n                         \"R$ \" & FORMAT(_val, \"#,##0.0\"))",
          Folder = "Revenue" },
    new { Name = "Total Orders Formatted",
          Dax = "VAR _val = [Total Orders]\nRETURN\n    SWITCH(TRUE(),\n        _val >= 1000000, FORMAT(_val / 1000000, \"0.0\") & \"M\",\n        _val >= 1000,    FORMAT(_val / 1000, \"0.0\") & \"K\",\n                         FORMAT(_val, \"#,##0\"))",
          Folder = "Revenue" },
    new { Name = "Avg Order Value Formatted",
          Dax = "VAR _val = [Avg Order Value]\nRETURN\n    SWITCH(TRUE(),\n        _val >= 1000000, \"R$ \" & FORMAT(_val / 1000000, \"0.0\") & \"M\",\n        _val >= 1000,    \"R$ \" & FORMAT(_val / 1000, \"0.0\") & \"K\",\n                         \"R$ \" & FORMAT(_val, \"#,##0.0\"))",
          Folder = "Revenue" },
    new { Name = "Avg Item Price Formatted",
          Dax = "VAR _val = [Avg Item Price]\nRETURN\n    SWITCH(TRUE(),\n        _val >= 1000000, \"R$ \" & FORMAT(_val / 1000000, \"0.0\") & \"M\",\n        _val >= 1000,    \"R$ \" & FORMAT(_val / 1000, \"0.0\") & \"K\",\n                         \"R$ \" & FORMAT(_val, \"#,##0.0\"))",
          Folder = "Revenue" },
    new { Name = "Avg Freight Value Formatted",
          Dax = "VAR _val = [Avg Freight Value]\nRETURN\n    SWITCH(TRUE(),\n        _val >= 1000000, \"R$ \" & FORMAT(_val / 1000000, \"0.0\") & \"M\",\n        _val >= 1000,    \"R$ \" & FORMAT(_val / 1000, \"0.0\") & \"K\",\n                         \"R$ \" & FORMAT(_val, \"#,##0.0\"))",
          Folder = "Revenue" },
    new { Name = "Total Items Sold Formatted",
          Dax = "VAR _val = [Total Items Sold]\nRETURN\n    SWITCH(TRUE(),\n        _val >= 1000000, FORMAT(_val / 1000000, \"0.0\") & \"M\",\n        _val >= 1000,    FORMAT(_val / 1000, \"0.0\") & \"K\",\n                         FORMAT(_val, \"#,##0\"))",
          Folder = "Revenue" },
    // ── Revenue — Total Revenue KPI ───────────────────────────────────────────
    new { Name = "Total Revenue CM Label",
          Dax = "VAR _last_ym = MAXX(FILTER(VALUES('mart dim_date'[year_month_key]), CALCULATE([Total Revenue]) > 0), 'mart dim_date'[year_month_key])\nVAR _cm_value = CALCULATE([Total Revenue], 'mart dim_date'[year_month_key] = _last_ym)\nVAR _cm_label = CALCULATE(MAX('mart dim_date'[month_year_short]), 'mart dim_date'[year_month_key] = _last_ym)\nVAR _fmt = SWITCH(TRUE(), _cm_value >= 1000000, FORMAT(_cm_value / 1000000, \"0.0\") & \"M\", _cm_value >= 1000, FORMAT(_cm_value / 1000, \"0.0\") & \"K\", FORMAT(_cm_value, \"#,##0\"))\nRETURN IF(ISBLANK(_cm_value), BLANK(), _cm_label & \" · R$ \" & _fmt)",
          Folder = "Revenue" },
    new { Name = "Total Revenue PM Label",
          Dax = "VAR _last_ym = MAXX(FILTER(VALUES('mart dim_date'[year_month_key]), CALCULATE([Total Revenue]) > 0), 'mart dim_date'[year_month_key])\nVAR _pm_ym = MAXX(FILTER(VALUES('mart dim_date'[year_month_key]), CALCULATE([Total Revenue]) > 0 && 'mart dim_date'[year_month_key] < _last_ym), 'mart dim_date'[year_month_key])\nVAR _pm_value = CALCULATE([Total Revenue], 'mart dim_date'[year_month_key] = _pm_ym)\nVAR _pm_label = CALCULATE(MAX('mart dim_date'[month_year_short]), 'mart dim_date'[year_month_key] = _pm_ym)\nVAR _fmt = SWITCH(TRUE(), _pm_value >= 1000000, FORMAT(_pm_value / 1000000, \"0.0\") & \"M\", _pm_value >= 1000, FORMAT(_pm_value / 1000, \"0.0\") & \"K\", FORMAT(_pm_value, \"#,##0\"))\nRETURN IF(ISBLANK(_pm_value), BLANK(), _pm_label & \" · R$ \" & _fmt)",
          Folder = "Revenue" },
    new { Name = "Total Revenue MoM Badge",
          Dax = "VAR _last_ym = MAXX(FILTER(VALUES('mart dim_date'[year_month_key]), CALCULATE([Total Revenue]) > 0), 'mart dim_date'[year_month_key])\nVAR _pm_ym = MAXX(FILTER(VALUES('mart dim_date'[year_month_key]), CALCULATE([Total Revenue]) > 0 && 'mart dim_date'[year_month_key] < _last_ym), 'mart dim_date'[year_month_key])\nVAR _cm = CALCULATE([Total Revenue], 'mart dim_date'[year_month_key] = _last_ym)\nVAR _pm = CALCULATE([Total Revenue], 'mart dim_date'[year_month_key] = _pm_ym)\nVAR _perc = FORMAT(DIVIDE(_cm - _pm, _pm), \"0.0%;0.0%\")\nRETURN IF(_cm - _pm > 0, UNICHAR(9650) & \" \" & _perc, UNICHAR(9660) & \" \" & _perc)",
          Folder = "Revenue" },
    new { Name = "Total Revenue Badge BG Color",
          Dax = "VAR _last_ym = MAXX(FILTER(VALUES('mart dim_date'[year_month_key]), CALCULATE([Total Revenue]) > 0), 'mart dim_date'[year_month_key])\nVAR _pm_ym = MAXX(FILTER(VALUES('mart dim_date'[year_month_key]), CALCULATE([Total Revenue]) > 0 && 'mart dim_date'[year_month_key] < _last_ym), 'mart dim_date'[year_month_key])\nVAR _cm = CALCULATE([Total Revenue], 'mart dim_date'[year_month_key] = _last_ym)\nVAR _pm = CALCULATE([Total Revenue], 'mart dim_date'[year_month_key] = _pm_ym)\nRETURN SWITCH(TRUE(), _cm - _pm > 0, \"#EAF8EC\", _cm - _pm < 0, \"#FFDCDC\", \"#F2F2F2\")",
          Folder = "Revenue" },
    new { Name = "Total Revenue Badge Text Color",
          Dax = "VAR _last_ym = MAXX(FILTER(VALUES('mart dim_date'[year_month_key]), CALCULATE([Total Revenue]) > 0), 'mart dim_date'[year_month_key])\nVAR _pm_ym = MAXX(FILTER(VALUES('mart dim_date'[year_month_key]), CALCULATE([Total Revenue]) > 0 && 'mart dim_date'[year_month_key] < _last_ym), 'mart dim_date'[year_month_key])\nVAR _cm = CALCULATE([Total Revenue], 'mart dim_date'[year_month_key] = _last_ym)\nVAR _pm = CALCULATE([Total Revenue], 'mart dim_date'[year_month_key] = _pm_ym)\nRETURN SWITCH(TRUE(), _cm - _pm > 0, \"Green\", _cm - _pm < 0, \"Red\", \"Grey\")",
          Folder = "Revenue" },
    // ── Revenue — Total Orders KPI ────────────────────────────────────────────
    new { Name = "Total Orders CM Label",
          Dax = "VAR _last_ym = MAXX(FILTER(VALUES('mart dim_date'[year_month_key]), CALCULATE([Total Orders]) > 0), 'mart dim_date'[year_month_key])\nVAR _cm_value = CALCULATE([Total Orders], 'mart dim_date'[year_month_key] = _last_ym)\nVAR _cm_label = CALCULATE(MAX('mart dim_date'[month_year_short]), 'mart dim_date'[year_month_key] = _last_ym)\nVAR _fmt = SWITCH(TRUE(), _cm_value >= 1000000, FORMAT(_cm_value / 1000000, \"0.0\") & \"M\", _cm_value >= 1000, FORMAT(_cm_value / 1000, \"0.0\") & \"K\", FORMAT(_cm_value, \"#,##0\"))\nRETURN IF(ISBLANK(_cm_value), BLANK(), _cm_label & \" · \" & _fmt)",
